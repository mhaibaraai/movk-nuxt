{
  "name": "@movk/nuxt",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@10.13.1",
  "description": "Movk Nuxt module",
  "license": "MIT",
  "repository": "movk/nuxt",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "dev": "nr dev:prepare && nuxi dev playground --port 4000",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "dev:build": "nuxi build playground",
    "docs:dev": "nuxi dev docs",
    "docs:build": "nuxi build docs",
    "release": "bumpp --commit \"release: v%s\" --push --tag",
    "prepack": "nr build",
    "publish": "pnpm publish --access public --no-git-checks",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "typecheck": "vue-tsc --noEmit && nuxt typecheck playground && nuxt typecheck docs",
    "up": "taze major -wIr",
    "clean": "tsx scripts/rm.ts"
  },
  "dependencies": {
    "@iconify-json/lucide": "catalog:icons",
    "@iconify-json/simple-icons": "catalog:icons",
    "@movk/core": "catalog:prod",
    "@nuxt/image": "catalog:frontend",
    "@nuxt/kit": "catalog:nuxt",
    "@nuxt/ui": "catalog:frontend",
    "@nuxt/ui-pro": "catalog:frontend",
    "@nuxtjs/i18n": "catalog:nuxt",
    "@vueuse/core": "catalog:frontend",
    "defu": "catalog:prod",
    "lru-cache": "catalog:prod",
    "nuxt-auth-utils": "catalog:nuxt",
    "pinia": "catalog:frontend",
    "zod": "catalog:frontend"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@antfu/ni": "catalog:cli",
    "@nuxt/devtools": "catalog:dev",
    "@nuxt/eslint": "catalog:dev",
    "@nuxt/module-builder": "catalog:dev",
    "@nuxt/schema": "catalog:dev",
    "@nuxt/test-utils": "catalog:test",
    "@pinia/nuxt": "catalog:frontend",
    "@types/node": "catalog:build",
    "@vueuse/nuxt": "catalog:frontend",
    "changelogen": "catalog:dev",
    "eslint": "catalog:dev",
    "eslint-plugin-format": "catalog:dev",
    "fast-glob": "catalog:cli",
    "lint-staged": "catalog:cli",
    "nuxt": "catalog:nuxt",
    "simple-git-hooks": "catalog:cli",
    "taze": "catalog:cli",
    "tsx": "catalog:cli",
    "typescript": "catalog:build",
    "vitest": "catalog:test",
    "vue-tsc": "catalog:build"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
