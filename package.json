{
  "name": "@movk/nuxt",
  "type": "module",
  "version": "1.2.0",
  "packageManager": "pnpm@11.5.0",
  "description": "Nuxt 4 modular engineering suite — schema-driven auto forms (Zod v4), API integration with auth & progress tracking, standalone UI components, and utility composables",
  "author": "YiXuan <mhaibaraai@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mhaibaraai/movk-nuxt.git"
  },
  "homepage": "https://nuxt.mhaibaraai.cn",
  "engines": {
    "node": "^22.x || >=24.x"
  },
  "bugs": {
    "url": "https://github.com/mhaibaraai/movk-nuxt/issues"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "nuxt4",
    "zod",
    "form",
    "auto-form",
    "schema-driven",
    "validation",
    "api",
    "fetch",
    "auth",
    "upload",
    "download",
    "composables",
    "ui-components"
  ],
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "style": "./dist/runtime/index.css",
      "import": "./dist/module.mjs"
    },
    "./runtime/*": "./dist/runtime/*",
    "./components/*": "./dist/runtime/components/*",
    "./composables": {
      "types": "./dist/runtime/composables/index.d.ts",
      "import": "./dist/runtime/composables/index.js"
    },
    "./composables/*": {
      "types": "./dist/runtime/composables/*.d.ts",
      "import": "./dist/runtime/composables/*.js"
    },
    "./utils/*": "./dist/runtime/utils/*",
    "./plugins/*": "./dist/runtime/plugins/*"
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/module.d.mts"
      ],
      "runtime/*": [
        "./dist/runtime/*"
      ],
      "components/*": [
        "./dist/runtime/components/*"
      ],
      "composables": [
        "./dist/runtime/composables/index.d.ts"
      ],
      "composables/*": [
        "./dist/runtime/composables/*.d.ts"
      ],
      "utils/*": [
        "./dist/runtime/utils/*.d.ts"
      ],
      "plugins/*": [
        "./dist/runtime/plugins/*.d.ts"
      ]
    }
  },
  "style": "./dist/runtime/index.css",
  "main": "./dist/module.mjs",
  "files": [
    ".nuxt/movk-ui.css",
    "dist"
  ],
  "peerDependencies": {
    "@nuxt/ui": ">=4.6.0",
    "zod": ">=4.3.6"
  },
  "scripts": {
    "prepack": "pnpm build",
    "build": "nuxt-module-build build",
    "dev": "nuxt dev playgrounds/play --uiDev",
    "dev:build": "nuxt build playgrounds/play",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playgrounds/play && nuxt prepare docs",
    "docs": "nuxt dev docs --uiDev",
    "docs:build": "nuxt build docs",
    "release": "release-it && npm publish",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "vue-tsc --noEmit && nuxt typecheck playgrounds/play && nuxt typecheck docs",
    "clean": "movk-clean",
    "test": "vitest"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.109",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/tabler": "^1.2.35",
    "@internationalized/date": "^3.12.1",
    "@movk/core": "^1.2.5",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.8.0",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "colortranslator": "^6.1.1",
    "defu": "^6.1.7",
    "maska": "^3.2.0",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-site-config": "^4.0.8",
    "reka-ui": "^2.9.7",
    "scule": "^1.3.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "unifont": "^0.7.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/kit": "^4.4.6",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.6",
    "@release-it/bumper": "^7.0.5",
    "@release-it/conventional-changelog": "^11.0.0",
    "eslint": "^10.4.0",
    "happy-dom": "^20.9.0",
    "nuxt": "^4.4.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "vue": "^3.5.34",
    "vue-tsc": "^3.3.1"
  }
}
